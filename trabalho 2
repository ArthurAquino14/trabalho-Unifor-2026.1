let nome = prompt("Nome do correntista: ");
let tipo = prompt("Digite o tipo de conta (1 - Conta Corrente, 2 - Conta Poupança, 3 - Conta Salário): ");
let operacao = prompt("Qual a operação desejada?(1 - Saque, 2 - Depósito, 3 - Consultar Saldo): ");
let saldo = prompt("Digite o saldo disponível na sua conta: ");
let valor = prompt("Qual o valor da operação desejada ?: ");
tipo = parseInt(tipo);
operacao =parseInt(operacao);
saldo = parseFloat(saldo);
valor =parseFloat(valor);

let limite;
let nomeOperacao;

// Tipo de conta
switch(tipo){
    case 1:
        limite = 3000;
        break;
    case 2:
        limite = 1500;
        break;
    case 3:
        limite = 2000;
        break;
    default:
        console.log("Tipo de conta inválido.");
        break;
}

// Nome da operação
switch(operacao){
    case 1:
        nomeOperacao = "Saque";
        break;
    case 2:
        nomeOperacao = "Depósito";
        break;
    case 3:
        nomeOperacao = "Consulta de saldo";
        break;
    default:
        console.log("Operação inválida.");
        break;
}

// Processamento
switch(true){
    case operacao === 1 && valor > limite:
        console.log("Saque negado --- valor acima do limite diário.");
        break;

    case operacao === 1 && valor > saldo:
        console.log("Saque negado --- saldo insuficiente.");
        break;

    case operacao === 1:
        saldo -= valor;
        console.log("Saque realizado com sucesso.");
        break;

    case operacao === 2:
        saldo += valor;
        console.log("Depósito realizado com sucesso.");
        break;

    case operacao === 3:
        console.log("Saldo atual: R$ " + saldo.toFixed(2));
        break;
}

// Status do saldo
console.log(saldo >= 0 ? "Saldo positivo" : "Saldo zerado/negativo");

// Exibir saldo final
console.log("Saldo final: R$ " + saldo.toFixed(2));
